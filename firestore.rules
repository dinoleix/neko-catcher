rules_version = '2';

// ============================================================
// GreenNeko shared Firestore rules (project: games-dd1a8)
// ------------------------------------------------------------
// This project's database is shared by multiple games:
//   • Cat Hunt Café  -> "leaderboard" + "prizes" collections
//   • Neko Catcher   -> "scores" collection (this PWA)
//
// Each game uses its OWN collection, so leaderboards stay separate.
// When adding a new game, give it its own collection + rule block here.
// ============================================================
service cloud.firestore {
  match /databases/{database}/documents {

    // =====================================================
    // Cat Hunt Café  (existing game — left exactly as-is)
    // =====================================================

    // ---- Leaderboard ----
    match /leaderboard/{entry} {
      allow read: if true;

      // A new score must look like a real score.
      allow create: if
        request.resource.data.name is string &&
        request.resource.data.name.size() <= 20 &&
        request.resource.data.cats is int &&
        request.resource.data.cats >= 0 && request.resource.data.cats <= 100 &&
        request.resource.data.timeMs is int &&
        request.resource.data.timeMs >= 0 &&
        request.resource.data.level is int;

      // Admin "set winner" tags an existing entry; allow updates but never let
      // the core score change, and never allow deletes.
      allow update: if
        request.resource.data.name == resource.data.name &&
        request.resource.data.cats == resource.data.cats &&
        request.resource.data.timeMs == resource.data.timeMs;
      allow delete: if false;
    }

    // ---- Prizes (admin config) ----
    match /prizes/{prize} {
      allow read: if true;
      allow write: if true; // admin panel manages these from the browser
    }

    // =====================================================
    // Neko Catcher  (this PWA — public weekly leaderboard)
    // =====================================================
    match /scores/{scoreId} {
      // Anyone may read the leaderboard.
      allow read: if true;

      // Anyone may submit a score, but it must be well-formed.
      allow create: if isValidScore(request.resource.data);

      // Scores are immutable from the client — no edits or deletes.
      allow update, delete: if false;
    }

    // Required: score (int), name (string), week (string).
    // Optional: game, createdAt, and any extra fields.
    function isValidScore(d) {
      return d.score is int && d.score >= 0 && d.score <= 1000000
        && d.name is string && d.name.size() > 0 && d.name.size() <= 40
        && d.week is string && d.week.size() > 0 && d.week.size() <= 16
        && (!('game' in d) || (d.game is string && d.game.size() <= 40))
        && (!('createdAt' in d) || d.createdAt is timestamp);
    }
  }
}
