rules_version = '2';

// ============================================================
// GreenNeko shared Firestore rules
// ------------------------------------------------------------
// One "scores" collection is shared across ALL GreenNeko games.
// Each row SHOULD be tagged with `game` (e.g. "neko-catcher") so
// every game can keep its own leaderboard.
//
// This is the TOLERANT ruleset: safe to deploy even if some of your
// older games don't tag `game` yet or write a few extra fields.
// It only enforces the minimum the leaderboard depends on
// (score / name / week) plus basic anti-abuse limits.
//
// Once EVERY game tags `game` and writes a server timestamp, switch
// to the STRICT block at the bottom for tighter validation.
// ============================================================
service cloud.firestore {
  match /databases/{database}/documents {

    // Public weekly leaderboard collection.
    match /scores/{scoreId} {
      // Anyone may read the leaderboard.
      allow read: if true;

      // Anyone may submit a score, but it must be well-formed.
      allow create: if isValidScore(request.resource.data);

      // Scores are immutable from the client — no edits or deletes.
      // (Manage/clear them from the Firebase console or Admin SDK.)
      allow update, delete: if false;
    }

    // --- TOLERANT validation (active) ---
    // Required: score (int), name (string), week (string).
    // Optional: game, createdAt, and any other fields your games add.
    function isValidScore(d) {
      return d.score is int && d.score >= 0 && d.score <= 1000000
        && d.name is string && d.name.size() > 0 && d.name.size() <= 40
        && d.week is string && d.week.size() > 0 && d.week.size() <= 16
        && (!('game' in d) || (d.game is string && d.game.size() <= 40))
        && (!('createdAt' in d) || d.createdAt is timestamp);
    }

    // --- STRICT validation (hardening upgrade) ---
    // Once all games tag `game` and use serverTimestamp(), replace the
    // call above with isValidScoreStrict and delete isValidScore:
    //
    // function isValidScoreStrict(d) {
    //   return d.keys().hasOnly(['game', 'name', 'score', 'week', 'createdAt'])
    //     && d.game is string && d.game.size() > 0 && d.game.size() <= 40
    //     && d.name is string && d.name.size() > 0 && d.name.size() <= 14
    //     && d.score is int && d.score >= 0 && d.score <= 1000000
    //     && d.week is string && d.week.size() > 0 && d.week.size() <= 12
    //     && d.createdAt == request.time;
    // }
  }
}
